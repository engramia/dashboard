NEXTAUTH_URL=https://app.engramia.dev
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32

NEXT_PUBLIC_API_URL=https://api.engramia.dev

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

NEXT_PUBLIC_STRIPE_PRO_URL=https://buy.stripe.com/your-pro-link
NEXT_PUBLIC_STRIPE_TEAM_URL=https://buy.stripe.com/your-team-link

# Public-facing URLs — override for self-hosted / branded deployments
NEXT_PUBLIC_LEGAL_TERMS_URL=https://engramia.dev/legal/terms
NEXT_PUBLIC_LEGAL_PRIVACY_URL=https://engramia.dev/legal/privacy
NEXT_PUBLIC_DOCS_URL=https://engramia.dev/docs

# E2E tests (Playwright) — credentials for a pre-seeded cloud user in Core
DASHBOARD_URL=http://localhost:3000
DASHBOARD_TEST_EMAIL=e2e@example.com
DASHBOARD_TEST_PASSWORD=change-me-in-local-env
